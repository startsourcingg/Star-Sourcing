true\">Energy-efficient and eco-friendly design for sustainable production<\/span><\/li>\r\n<\/ul>","featuredImage":"https:\/\/ptplabels.com\/wp-content\/uploads\/2025\/06\/Untitled-design-39-1024x1024.jpg"}};
